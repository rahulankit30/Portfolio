# ── Resend Email (Contact Form) ────────────────────────────────────────────────
# 1. Create a free account at https://resend.com
# 2. Generate an API key from the dashboard
# 3. Verify your sending domain (or use "onboarding@resend.dev" for testing)

RESEND_API_KEY=key

# The email address that receives contact form submissions
CONTACT_TO_EMAIL=rahulankit.30@gmail.com

# The "From" address — must match a verified domain in Resend
# For testing without a domain, use: Portfolio <onboarding@resend.dev>
CONTACT_FROM_EMAIL=Portfolio <onboarding@resend.dev>

# ── Site URL (for SEO metadata) ────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://rahul-ankit.vercel.app
